# ============================================================
# DeepAgent Azure CLI — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit the .env file to git!
# ============================================================

# Required: Azure OpenAI connection
# ---
# AZURE_OPENAI_ENDPOINT can be either the base URL or the full URL:
#   Base:  https://my-resource.openai.azure.com
#   Full:  https://my-resource.openai.azure.com/openai/responses?api-version=2025-04-01-preview
# The CLI will automatically extract the base URL and api-version.
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment name — any of these env var names work:
#   AZURE_OPENAI_DEPLOYMENT_NAME, AZURE_OPENAI_DEPLOYMENT, AZURE_OPENAT_DEPLOYMENT
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.3-codex

# Optional: Agent behaviour
# DEEPAGENT_APPROVE_SHELL=true
# DEEPAGENT_APPROVE_WRITES=true
# DEEPAGENT_ROOT_DIR=.
# DEEPAGENT_MAX_RETRIES=6
# DEEPAGENT_TIMEOUT=120

# Optional: Session persistence (default: in-memory)
# DEEPAGENT_CHECKPOINT_DB=~/.deepagent-azure/sessions.db

# Optional: Web search (install with: pip install deepagent-azure-cli[search])
# DEEPAGENT_ENABLE_SEARCH=false
# TAVILY_API_KEY=your-tavily-key
