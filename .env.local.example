# ============================================================
# DeepAgent Azure CLI — Local MLX Server Configuration
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit the .env file to git!
# ============================================================
#
# This configuration targets a local MLX inference server that
# emulates the Azure OpenAI API (Chat + Responses, including
# tool calls). Requires:
#
#   https://github.com/ai-agents-cybersecurity/mlx-local-server-chat-and-responses
#
# Start the server first, then run deepagent-azure as usual.
# ============================================================

# Local MLX server connection
AZURE_OPENAI_API_KEY=local
AZURE_OPENAI_ENDPOINT=http://localhost:8080
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment name — the MLX server ignores this, but the CLI requires it.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.3-codex

# Optional: Agent behaviour
# DEEPAGENT_APPROVE_SHELL=true
# DEEPAGENT_APPROVE_WRITES=true
# DEEPAGENT_ROOT_DIR=.
# DEEPAGENT_MAX_RETRIES=6
# DEEPAGENT_TIMEOUT=120

# Optional: Session persistence (default: in-memory)
# DEEPAGENT_CHECKPOINT_DB=~/.deepagent-azure/sessions.db

# Optional: Web search (install with: pip install deepagent-azure-cli[search])
# DEEPAGENT_ENABLE_SEARCH=false
# TAVILY_API_KEY=your-tavily-key
